
{
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  font-family: 'Poppins', sans-serif;
  background-color: #ffffff;
  color: #333333;
  line-height: 1.6;
}

/* I picked these as my main colors so I can reuse them everywhere */
:root {
  --main-color: #e0982a;      /* warm amber/gold, main buttons and highlights */
  --dark-color: #3b2e1a;      /* warm dark brown for header/footer background */
  --light-bg: #fdf6e9;        /* warm cream background for some sections */
  --text-grey: #6b5f4f;
}

h1, h2, h3 {
  font-family: 'Poppins', sans-serif;
  font-weight: 600;
}

a {
  text-decoration: none;
  color: inherit;
}

ul {
  list-style: none;
}

img {
  max-width: 100%;
}

.container {
  max-width: 1000px;
  margin: 0 auto;
  padding: 20px;
}

.section-title {
  text-align: center;
  margin-bottom: 30px;
  font-size: 28px;
  color: var(--dark-color);
}

.btn {
  display: inline-block;
  background-color: var(--main-color);
  color: #ffffff;
  padding: 12px 24px;
  border: none;
  border-radius: 5px;
  cursor: pointer;
  font-size: 16px;
  margin-top: 10px;
}

.btn:hover {
  background-color: #b5771e;
}

/* ==========================================
   HEADER / NAVIGATION
   ========================================== */
header {
  background-color: var(--dark-color);
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  z-index: 999;
}

.nav-container {
  max-width: 1000px;
  margin: 0 auto;
  padding: 15px 20px;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.logo {
  color: #ffffff;
}

nav ul {
  display: flex;
}

nav ul li {
  margin-left: 25px;
}

nav ul li a {
  color: #ffffff;
  font-size: 15px;
}

nav ul li a:hover {
  color: var(--main-color);
}

/* The hamburger button is hidden by default on big screens */
#menu-btn {
  display: none;
  background: none;
  border: 1px solid #ffffff;
  color: #ffffff;
  padding: 6px 12px;
  border-radius: 4px;
  cursor: pointer;
  font-size: 16px;
}

/* ==========================================
   HOME SECTION
   ========================================== */
#home {
  background-color: var(--dark-color);
  color: #ffffff;
  text-align: center;
  padding: 150px 20px 80px 20px;
}

.profile-pic {
  width: 120px;
  height: 120px;
  border-radius: 50%;
  object-fit: cover;
  border: 3px solid var(--main-color);
  margin: 0 auto 20px auto;
}

#home h1 {
  font-size: 36px;
  margin-bottom: 5px;
}

#home #profile-role {
  color: var(--main-color);
  font-size: 18px;
  margin-bottom: 15px;
}

#home #profile-tagline {
  max-width: 500px;
  margin: 0 auto 20px auto;
  color: #cccccc;
}

/* ==========================================
   ABOUT SECTION
   ========================================== */
#about {
  background-color: #ffffff;
  padding: 60px 0;
  text-align: center;
}

#about p {
  margin-bottom: 12px;
  color: var(--text-grey);
}

/* ==========================================
   SKILLS SECTION
   ========================================== */
#skills {
  background-color: var(--light-bg);
  padding: 60px 0;
}

"skills": [
  { "name": "HTML", "level": 50, "category": "Structure" },
  { "name": "CSS", "level": 40, "category": "Style" },
  { "name": "JavaScript", "level": 30, "category": "Logic" },
  { "name": "Prototyping", "level": 70, "category": "Design" },
  { "name": "Figma", "level": 78, "category": "Tooling" }
]

/* Each skill card, one per skill in data.json */
.skill-card {
  background-color: #ffffff;
  border: 1px solid #e0e0e0;
  border-radius: 6px;
  padding: 15px 20px;
  margin-bottom: 15px;
}

.skill-top-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8px;
}

.skill-top-row span {
  font-weight: 600;
}

.skill-bar-background {
  width: 100%;
  height: 10px;
  background-color: #e0e0e0;
  border-radius: 5px;
}

.skill-bar-fill {
  height: 10px;
  background-color: var(--main-color);
  border-radius: 5px;
}

/* ==========================================
   PROJECTS SECTION
   ========================================== */
#projects {
  background-color: #ffffff;
  padding: 60px 0;
}

.project-card {
  background-color: var(--light-bg);
  border: 1px solid #e0e0e0;
  border-radius: 6px;
  padding: 20px;
  margin-bottom: 20px;
}

.project-image {
  width: 100%;
  height: 180px;
  object-fit: cover;
  border-radius: 4px;
  margin-bottom: 15px;
}

.project-card h3 {
  margin-bottom: 8px;
  color: var(--dark-color);
}

.project-card p {
  color: var(--text-grey);
  margin-bottom: 10px;
}

.project-tag {
  display: inline-block;
  background-color: #faead0;
  color: var(--main-color);
  font-size: 12px;
  padding: 4px 10px;
  border-radius: 12px;
  margin-right: 6px;
  margin-bottom: 6px;
}

.project-link {
  color: var(--main-color);
  font-weight: 600;
}

/* ==========================================
   EDUCATION SECTION
   ========================================== */
#education {
  background-color: var(--light-bg);
  padding: 60px 0;
}

.education-card {
  background-color: #ffffff;
  border-left: 4px solid var(--main-color);
  padding: 15px 20px;
  margin-bottom: 20px;
}

.education-card .period {
  color: var(--main-color);
  font-size: 14px;
  font-weight: 600;
}

.education-card h3 {
  margin: 5px 0;
}

.education-card .place {
  color: var(--text-grey);
  font-size: 14px;
  margin-bottom: 8px;
}

/* ==========================================
   CONTACT SECTION
   ========================================== */
#contact {
  background-color: #ffffff;
  padding: 60px 0;
  text-align: center;
}

#contact-form {
  max-width: 500px;
  margin: 20px auto 0 auto;
  text-align: left;
}

#contact-form label {
  display: block;
  margin-top: 12px;
  margin-bottom: 5px;
  font-weight: 600;
}

#contact-form input,
#contact-form textarea {
  width: 100%;
  padding: 10px;
  border: 1px solid #cccccc;
  border-radius: 4px;
  font-family: 'Poppins', sans-serif;
}

/* ==========================================
   FOOTER
   ========================================== */
footer {
  background-color: var(--dark-color);
  color: #ffffff;
  text-align: center;
  padding: 20px;
  font-size: 14px;
}

/* ==========================================
   RESPONSIVE DESIGN
   Mobile first would be nice, but I built the
   desktop layout first and then adjusted it
   for smaller screens using media queries.
   ========================================== */

/* TABLET: 768px and below */
@media (max-width: 768px) {

  #menu-btn {
    display: block;
  }

  nav#nav-menu {
    display: none;
    width: 100%;
  }

  /* When JavaScript adds the "show-menu" class, the menu appears */
  nav#nav-menu.show-menu {
    display: block;
  }

  .nav-container {
    flex-wrap: wrap;
  }

  nav#nav-menu ul {
    flex-direction: column;
    width: 100%;
  }

  nav#nav-menu ul li {
    margin: 0;
    border-top: 1px solid #55432a;
  }

  nav#nav-menu ul li a {
    display: block;
    padding: 12px 0;
  }
}

/* MOBILE PHONES: 480px and below */
@media (max-width: 480px) {

  #home {
    padding: 120px 15px 60px 15px;
  }

  #home h1 {
    font-size: 28px;
  }

  .section-title {
    font-size: 22px;
  }

  .container {
    padding: 15px;
  }
}
